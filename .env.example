# Copy to .env on each docker host and fill in real values.
# .env is gitignored so credentials never leave the host.

# Where final clips land. Each camera gets its own subfolder by NAME.
# Layout: ${RECORDING_PATH}/<camera_name>/<YYYY-MM-DD>/<ts>.mp4
RECORDING_PATH=/recordings

# Where the rolling segment ring buffer lives (one subdir per camera).
# Should be a tmpfs mount in production to avoid wearing real disks.
TMPFS_PATH=/tmp/cam-segments

# Motion threshold: average per-pixel luma difference (0-255) between
# consecutive sampled frames above which we declare motion. Lower = more
# sensitive. Typical values: static scene 0.5-2 (sensor noise), person
# walking 5-30+. Watch the per-minute "motion stats: max_yavg=..." log
# line and pick a value just above your idle baseline.
MOTION_THRESHOLD=4.0

# Cameras are configured in numbered slots starting at 1. Add CAMERA_2_*,
# CAMERA_3_*, … as needed. The loader stops at the first gap.
#
# NAME is used as the on-disk folder; restrict to [A-Za-z0-9_-].
# IP appears in clip filenames for traceability when names collide across hosts.

CAMERA_1_NAME=front
CAMERA_1_RTSP=rtsp://USER:PASS@192.168.X.X:554/live/ch0
CAMERA_1_IP=192.168.X.X

# CAMERA_2_NAME=back
# CAMERA_2_RTSP=rtsp://USER:PASS@192.168.X.X:554/live/ch0
# CAMERA_2_IP=192.168.X.X

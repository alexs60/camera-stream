# Copy to .env on each docker VM and fill in real values.
# .env is gitignored so credentials never leave the host.

# RTSP stream URL — credentials inline.
RTSP_URL=rtsp://USER:PASS@192.168.X.X:554/live/ch0

# Camera identifier — appears in recorded filenames.
CAMERA_IP=192.168.X.X

# Motion sensitivity threshold (changed-pixel count). Lower = more sensitive.
MOTION_SENSITIVITY=500

# Processing/encoding rate. Drop this if libx264 can't keep up; raise it
# (e.g. 20-25) if you have CPU headroom and want smoother motion.
TARGET_FPS=15
